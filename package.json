{
  "name": "@oclka/blueprint-ts",
  "version": "0.0.0",
  "description": "The definitive blueprint for building battle-tested, production-ready TypeScript libraries.",
  "author": {
    "name": "OCLKA",
    "email": "bonjour@olcka.dev",
    "url": "https://oclka.dev"
  },
  "license": "MIT",
  "private": true,
  "keywords": [
    "typescript",
    "blueprint",
    "boilerplate",
    "library",
    "template",
    "starter",
    "dx",
    "best-practices",
    "production-ready",
    "battle-tested"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsx src/index.ts",
    "check:types": "tsc --noEmit",
    "check:all": "pnpm check:types && pnpm lint:fix && true",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
