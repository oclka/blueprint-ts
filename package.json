{
  "name": "@oclka/blueprint-ts",
  "version": "0.0.0",
  "description": "The definitive blueprint for building battle-tested, production-ready TypeScript libraries.",
  "author": {
    "name": "OCLKA",
    "email": "bonjour@olcka.dev",
    "url": "https://oclka.dev"
  },
  "license": "MIT",
  "private": true,
  "keywords": [
    "typescript",
    "blueprint",
    "boilerplate",
    "library",
    "template",
    "starter",
    "dx",
    "best-practices",
    "production-ready",
    "battle-tested"
  ],
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsx src/index.ts",
    "check:types": "tsc --noEmit",
    "check:pkg": "publint && attw --pack",
    "check:size": "size-limit",
    "check:secrets": "if command -v gitleaks > /dev/null; then gitleaks protect --staged --verbose; else echo '⚠️ gitleaks is not installed locally. Skipping secret scan.'; fi",
    "check:all": "pnpm check:types && pnpm lint:fix && pnpm check:secrets && pnpm audit --audit-level=high && pnpm build && pnpm check:pkg && pnpm check:size && true",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write ."
  },
  "packageManager": "pnpm@10.30.3",
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-tsdoc": "^0.5.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.18",
    "size-limit": "^12.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  }
}
